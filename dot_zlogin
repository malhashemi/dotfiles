# ~/.zlogin — auto-attach `cmux ssh` interactive shells to a per-workspace
# zellij session for laptop-close durability + per-pane sequential tab assignment.
#
# Triggers ONLY when:
#   - On Linux (no-op on macOS where cmux runs as the local terminal app)
#   - Interactive shell
#   - Inside `cmux ssh` (CMUX_SOCKET_PATH set by cmux's session shell init)
#   - Not already inside zellij ($ZELLIJ unset)
#   - Not opted out (CMUX_NO_ZELLIJ unset)
#   - EITHER a staging file (from Mac-side `cdevbox`) OR a workspace marker
#     left by a primary pane in the same cmux workspace exists
#
# Behavior matrix (inside an active cdevbox workspace):
#   - Primary pane (`cdevbox foo`)
#       → zellij attach --create foo (lands on tab position 0)
#       → marker initialized to "foo:1" (next sibling targets position 1)
#
#   - Sibling pane (Cmd+D or Cmd+T) — both behave identically:
#       Read marker's next_pos, then:
#         IF next_pos < total_tabs → zellij action go-to-tab (next_pos + 1)
#         ELSE                     → zellij action new-tab
#       Either way: write back "foo:$((next_pos + 1))" so the next sibling
#       advances. Each Cmd+D/T cycles forward through existing tabs and only
#       creates a new tab when it runs off the end.
#
#   - Bare `cmuxbox` (no staging/marker) → fall through to plain shell
#
# Use Ctrl+N inside zellij to make panes WITHIN a tab.
# Use Alt+H/Alt+L/Alt+1..5 to manually navigate this viewport between tabs.
#
# Counter caveat: the position counter monotonically advances. If you close
# zellij tabs (not just cmux panes), the counter doesn't rewind — eventually
# next_pos exceeds total_tabs and Cmd+D resumes creating new tabs at the end.
# That self-corrects within a few presses; explicit reset isn't worth the
# complexity.
#
# See dot_zshrc.tmpl for the matching Mac-side `cdevbox` function.

if [[ "$OSTYPE" != linux* ]]; then return; fi
if [[ -z "$CMUX_SOCKET_PATH" || -n "$ZELLIJ" || -n "$CMUX_NO_ZELLIJ" ]]; then return; fi
[[ -o interactive ]] || return

emulate -L zsh
zmodload zsh/datetime 2>/dev/null

local stage="$HOME/.cmux/next-zellij-session"
local marker_dir="$HOME/.cmux/workspace-zellij"
local marker=""
[[ -n "$CMUX_WORKSPACE_ID" ]] && marker="$marker_dir/$CMUX_WORKSPACE_ID"

# Housekeeping: purge orphaned workspace markers older than 7 days.
[[ -d "$marker_dir" ]] && find "$marker_dir" -type f -mtime +7 -delete 2>/dev/null

local zsess="" is_sibling=false next_pos=1

# Path 1: Mac-side `cdevbox` staged the session name → primary pane.
if [[ -r "$stage" ]]; then
  local now=${EPOCHSECONDS:-$(date +%s)}
  local stamp=$(stat -c %Y "$stage" 2>/dev/null || echo 0)
  if (( now - stamp < 300 )); then
    zsess=$(<"$stage"); zsess=${zsess//[$'\n\r']/}
  fi
  rm -f "$stage"
fi

# Path 2: Sibling pane (Cmd+D or Cmd+T) in an existing cdevbox-tagged workspace.
# Marker format: "<session>:<next_pos>" where next_pos is the 0-indexed tab
# position the next sibling should target. Legacy ":<tab_id_uuid>" markers
# are treated as next_pos=1 (sane default).
if [[ -z "$zsess" && -n "$marker" && -r "$marker" ]]; then
  local mc=$(<"$marker"); mc=${mc//[$'\n\r']/}
  zsess=${mc%%:*}
  local stored=${mc#*:}
  if [[ "$stored" =~ ^[0-9]+$ ]]; then
    next_pos=$stored
  fi
  is_sibling=true
fi

# Bare cmuxbox (no durability context requested) → plain shell.
[[ -n "$zsess" ]] || return

if $is_sibling; then
  # Cycle: focus the next existing tab, OR create a new one if we've run off the end.
  local total_tabs=$(zellij --session "$zsess" action query-tab-names 2>/dev/null | wc -l)
  if (( next_pos < total_tabs )); then
    # Tab at this position exists. zellij's go-to-tab is 1-based; position is 0-based.
    zellij --session "$zsess" action go-to-tab $((next_pos + 1)) 2>/dev/null
  else
    # No existing tab to cycle to → create one (auto-focuses for the creating session).
    zellij --session "$zsess" action new-tab >/dev/null 2>&1
  fi
  # Advance the counter for the next sibling.
  print -r -- "${zsess}:$((next_pos + 1))" > "$marker"
elif [[ -n "$marker" && ! -f "$marker" ]]; then
  # Primary pane: initialize marker. Primary is at position 0; first sibling targets 1.
  mkdir -p "$marker_dir" 2>/dev/null
  print -r -- "${zsess}:1" > "$marker"
fi

exec zellij attach --create "$zsess"
