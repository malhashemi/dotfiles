# ~/.zlogin — auto-attach `cmux ssh` interactive shells to a per-workspace
# zellij session for laptop-close durability + source-relative tab cycling.
#
# Triggers ONLY when:
#   - On Linux (no-op on macOS where cmux runs as the local terminal app)
#   - Interactive shell
#   - Inside `cmux ssh` (CMUX_SOCKET_PATH set by cmux's session shell init)
#   - Not already inside zellij ($ZELLIJ unset)
#   - Not opted out (CMUX_NO_ZELLIJ unset)
#   - EITHER a staging file (from Mac-side `cdevbox`) OR a workspace marker
#     left by a primary pane in the same cmux workspace exists
#
# Behavior matrix (inside an active cdevbox workspace):
#   - Primary pane (`cdevbox foo`)
#       → zellij attach --create foo (lands on tab position 0)
#       → marker initialized to "foo"
#
#   - Sibling pane (Cmd+D or Cmd+T) — both behave identically:
#       Query the SOURCE pane's current zellij tab position via
#       `zellij action current-tab-info`. This works because at the moment
#       the new pane's .zlogin runs, the new pane has not yet attached, so
#       zellij's "most-recently-focused client" is still the source pane —
#       the one in which the user pressed Cmd+D. Then:
#         IF source_pos + 1 < total_tabs → focus tab (source_pos + 1)
#         ELSE                           → create new tab (auto-focuses)
#       New attachment lands on the target/created tab.
#
#   - Bare `cmuxbox` (no staging/marker) → fall through to plain shell
#
# ⚠ Known caveat: when focusing an existing tab, zellij's go-to-tab from
# outside the session has no per-client targeting (mirror_session=false +
# no `--client-id` flag in zellij CLI). The source pane's view also yanks
# to the same tab; press Alt+H/L to navigate it back.
#
# Use Ctrl+N inside zellij to make panes WITHIN a tab.
# Use Alt+H/Alt+L/Alt+1..5 to manually navigate a viewport between tabs.
#
# See dot_zshrc.tmpl for the matching Mac-side `cdevbox` function.

if [[ "$OSTYPE" != linux* ]]; then return; fi
if [[ -z "$CMUX_SOCKET_PATH" || -n "$ZELLIJ" || -n "$CMUX_NO_ZELLIJ" ]]; then return; fi
[[ -o interactive ]] || return

emulate -L zsh
zmodload zsh/datetime 2>/dev/null

local stage="$HOME/.cmux/next-zellij-session"
local marker_dir="$HOME/.cmux/workspace-zellij"
local marker=""
[[ -n "$CMUX_WORKSPACE_ID" ]] && marker="$marker_dir/$CMUX_WORKSPACE_ID"

# Housekeeping: purge orphaned workspace markers older than 7 days.
[[ -d "$marker_dir" ]] && find "$marker_dir" -type f -mtime +7 -delete 2>/dev/null

local zsess="" is_sibling=false

# Path 1: Mac-side `cdevbox` staged the session name → primary pane.
if [[ -r "$stage" ]]; then
  local now=${EPOCHSECONDS:-$(date +%s)}
  local stamp=$(stat -c %Y "$stage" 2>/dev/null || echo 0)
  if (( now - stamp < 300 )); then
    zsess=$(<"$stage"); zsess=${zsess//[$'\n\r']/}
  fi
  rm -f "$stage"
fi

# Path 2: Sibling pane (Cmd+D or Cmd+T) in an existing cdevbox-tagged workspace.
# Marker stores just the session name; back-compat strip for any legacy
# ":<n>" or ":<tab_id_uuid>" suffix from prior implementations.
if [[ -z "$zsess" && -n "$marker" && -r "$marker" ]]; then
  local mc=$(<"$marker"); mc=${mc//[$'\n\r']/}
  zsess=${mc%%:*}
  is_sibling=true
fi

# Bare cmuxbox (no durability context requested) → plain shell.
[[ -n "$zsess" ]] || return

# Persist the workspace marker once (only the primary writes it).
if [[ -n "$marker" && ! -f "$marker" ]]; then
  mkdir -p "$marker_dir" 2>/dev/null
  print -r -- "$zsess" > "$marker"
fi

# Sibling: source-relative cycle-or-create.
if $is_sibling; then
  # Source pane = whoever the user pressed Cmd+D in. Their zellij client is
  # the most-recently-focused at the moment we run (we haven't attached yet).
  local cur_pos
  cur_pos=$(zellij --session "$zsess" action current-tab-info 2>/dev/null | awk '/^position:/ {print $2}')
  [[ "$cur_pos" =~ ^[0-9]+$ ]] || cur_pos=0

  local total_tabs
  total_tabs=$(zellij --session "$zsess" action query-tab-names 2>/dev/null | wc -l)

  local target=$((cur_pos + 1))

  if (( target < total_tabs )); then
    # Tab to the right of source's tab exists → focus it.
    # NOTE: this also yanks the source pane's view; user navigates back with Alt+H.
    zellij --session "$zsess" action go-to-tab $((target + 1)) 2>/dev/null
  else
    # Source was on the rightmost tab → create new (auto-focuses for next attach).
    zellij --session "$zsess" action new-tab >/dev/null 2>&1
  fi
fi

exec zellij attach --create "$zsess"
