# Ghostty Configuration
# https://ghostty.org/docs/config

# Theme - managed by theme system
# Static: theme = Catppuccin <Variant>
# Dynamic: config-file = colors-ghostty.conf
{{- if eq .theme.name "dynamic" }}
config-file = colors-ghostty.conf
{{- else }}
theme = Catppuccin {{ .theme.name | title }}
{{- end }}

# Font
font-family = {{ .preferences.terminal.font_family }}
font-size = {{ .preferences.terminal.font_size }}

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration = false

# Cursor
cursor-style = bar
cursor-style-blink = true

# Shell integration
shell-integration = zsh

# Option acts as a real Alt modifier so Herdr's alt+1..9 (switch_tab) reaches it,
# instead of macOS composing glyphs (¡™£). Matches the kitty/wezterm setup.
macos-option-as-alt = true

# Behavior (match wezterm: no confirm on close)
confirm-close-surface = false

# Keybinds — Ghostty as a DUMB HOST for Herdr (terminal multiplexer owns all
# tabs/splits/spaces). `keybind = clear` wipes ALL bindings incl. defaults so
# nothing shadows a Herdr chord; everything falls through via kitty keyboard
# protocol. We then re-add only a minimal keep-list.
keybind = clear
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
keybind = cmd+q=quit
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size
# Config reload — REQUIRED: the theme system reloads Ghostty by sending
# cmd+shift+, via osascript, so this must stay bound or live theming breaks.
keybind = cmd+shift+comma=reload_config
keybind = cmd+comma=open_config
keybind = ctrl+q=toggle_fullscreen
keybind = ctrl+apostrophe=clear_screen
keybind = cmd+k=clear_screen
keybind = cmd+ctrl+t=toggle_window_decorations
{{- $opacity := .theme.opacity | default 0 }}
{{- if and (gt $opacity 0) (lt $opacity 100) }}

# Transparency (managed by theme system)
background-opacity = {{ printf "%.2f" (divf (float64 $opacity) 100.0) }}
{{- if eq .chezmoi.os "darwin" }}
background-blur = 80
{{- end }}
{{- end }}
