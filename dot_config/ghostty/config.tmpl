# Ghostty Configuration
# https://ghostty.org/docs/config

# Theme - managed by theme system
# Static: theme = Catppuccin <Variant>
# Dynamic: config-file = colors-ghostty.conf
{{- if eq .theme.name "dynamic" }}
config-file = colors-ghostty.conf
{{- else }}
theme = Catppuccin {{ .theme.name | title }}
{{- end }}

# Font
font-family = {{ .preferences.terminal.font_family }}
font-size = {{ if and (eq .chezmoi.os "linux") (hasKey .preferences.terminal "font_size_linux") }}{{ .preferences.terminal.font_size_linux }}{{ else }}{{ .preferences.terminal.font_size }}{{ end }}

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration = false

# Cursor
cursor-style = bar
cursor-style-blink = true

# Shell integration
shell-integration = zsh

{{- if eq .chezmoi.os "darwin" }}
# Send Option as Alt so Herdr receives option-based app chords.
macos-option-as-alt = true
{{- end }}

# Behavior (match wezterm: no confirm on close)
confirm-close-surface = false

# Herdr owns tabs, splits, and workspaces; Ghostty keeps only host actions.
keybind = clear
{{- if eq .chezmoi.os "darwin" }}
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
keybind = cmd+q=quit
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size
# Required by the theme-system reload hook.
keybind = cmd+shift+comma=reload_config
keybind = cmd+comma=open_config
keybind = ctrl+q=toggle_fullscreen
keybind = ctrl+apostrophe=clear_screen
# cmd+k freed for Herdr pane-nav (focus_pane_up); clear_screen stays on ctrl+'
keybind = cmd+ctrl+t=toggle_window_decorations
{{- else }}
keybind = alt+c=copy_to_clipboard
keybind = alt+v=paste_from_clipboard
keybind = alt+q=quit
keybind = alt+equal=increase_font_size:1
keybind = alt+minus=decrease_font_size:1
keybind = alt+zero=reset_font_size
# Required by the theme-system reload hook.
keybind = alt+shift+comma=reload_config
keybind = ctrl+shift+comma=reload_config
keybind = ctrl+alt+r=reload_config
keybind = alt+comma=open_config
keybind = ctrl+q=toggle_fullscreen
keybind = ctrl+apostrophe=clear_screen
# alt+k freed for Herdr pane-nav (focus_pane_up); clear_screen stays on ctrl+'
keybind = alt+ctrl+t=toggle_window_decorations
{{- end }}
{{- $opacity := .theme.opacity | default 0 }}
{{- if and (gt $opacity 0) (lt $opacity 100) }}

# Transparency (managed by theme system)
background-opacity = {{ printf "%.2f" (divf (float64 $opacity) 100.0) }}
{{- if eq .chezmoi.os "darwin" }}
background-blur = 80
{{- end }}
{{- end }}
