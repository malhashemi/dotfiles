{{- /* Ghostty Colors - Generated by theme system */ -}}
{{- /* Bootstrap template; theme-manager.py overwrites this at runtime. */ -}}
{{- /* See .config/theme-system/scripts/apps/ghostty.py for runtime generation. */ -}}
{{- if eq .theme.name "dynamic" -}}
# Ghostty Colors - Dynamic Theme
# Generated by chezmoi from Material Design 3 palette
# Mode: {{ .theme.variant }}

# Basic colors
foreground = {{ .theme.material.on_surface }}
background = {{ .theme.material.background }}

# Cursor
cursor-color = {{ .theme.material.primary }}
cursor-text = {{ .theme.material.on_primary }}

# Selection
selection-foreground = {{ .theme.material.on_primary_container }}
selection-background = {{ .theme.material.primary_container }}

# ANSI colors (16-color palette)
{{- if eq .theme.variant "light" }}
palette = 0={{ .theme.material.surface_container_high }}
palette = 1={{ .theme.material.error }}
palette = 2={{ .theme.material.tertiary }}
palette = 3={{ .theme.material.secondary }}
palette = 4={{ .theme.material.primary }}
palette = 5={{ .theme.material.primary }}
palette = 6={{ .theme.material.tertiary }}
palette = 7={{ .theme.material.on_surface }}
palette = 8={{ .theme.material.outline }}
palette = 9={{ .theme.material.error }}
palette = 10={{ .theme.material.tertiary }}
palette = 11={{ .theme.material.secondary }}
palette = 12={{ .theme.material.primary }}
palette = 13={{ .theme.material.primary }}
palette = 14={{ .theme.material.tertiary }}
palette = 15={{ .theme.material.on_surface_variant }}
{{- else }}
palette = 0={{ .theme.material.outline }}
palette = 1={{ .theme.material.error }}
palette = 2={{ .theme.material.tertiary }}
palette = 3={{ .theme.material.secondary }}
palette = 4={{ .theme.material.primary }}
palette = 5={{ .theme.material.primary }}
palette = 6={{ .theme.material.tertiary }}
palette = 7={{ .theme.material.on_surface }}
palette = 8={{ .theme.material.surface_container }}
palette = 9={{ .theme.material.error }}
palette = 10={{ .theme.material.tertiary }}
palette = 11={{ .theme.material.secondary }}
palette = 12={{ .theme.material.primary }}
palette = 13={{ .theme.material.primary }}
palette = 14={{ .theme.material.tertiary }}
palette = 15={{ .theme.material.on_surface_variant }}
{{- end }}
{{- else -}}
# Ghostty Colors - Static theme uses `theme = Catppuccin {{ .theme.name | title }}` in main config.
# This file is unread for static themes.
{{- end }}
