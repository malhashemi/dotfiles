onboarding = false

[theme]
name = "custom-dynamic"

[theme.custom]
panel_bg = "{{ .theme.material.surface_container | default "#1e1e2e" }}"
surface0 = "{{ .theme.material.surface_container_low | default "#313244" }}"
surface1 = "{{ .theme.material.surface_container_high | default "#45475a" }}"
surface_dim = "{{ .theme.material.surface_dim | default "#181825" }}"
overlay0 = "{{ .theme.material.outline | default "#6c7086" }}"
overlay1 = "{{ .theme.material.outline_variant | default "#7f849c" }}"
text = "{{ .theme.material.on_surface | default "#cdd6f4" }}"
subtext0 = "{{ .theme.material.on_surface_variant | default "#a6adc8" }}"
mauve = "{{ .theme.material.primary | default "#cba6f7" }}"
blue = "{{ .theme.material.primary | default "#89b4fa" }}"
teal = "{{ .theme.material.tertiary | default "#94e2d5" }}"
green = "{{ .theme.material.tertiary | default "#a6e3a1" }}"
yellow = "{{ .theme.material.secondary | default "#f9e2af" }}"
peach = "{{ .theme.material.secondary | default "#fab387" }}"
red = "{{ .theme.material.error | default "#f38ba8" }}"
accent = "{{ .theme.material.primary | default "#89b4fa" }}"

[update]
channel = "stable"
shell_mode = "auto"
new_cwd = "follow"

[ui.sound]
enabled = true

[ui.toast]
delivery = "system"

[ui]
show_agent_labels_on_pane_borders = true
agent_panel_scope = "all"

# Keybindings
[keys]
prefix = "ctrl+b"

# Sidebar
{{- if eq .chezmoi.os "darwin" }}
toggle_sidebar = ["prefix+b", "cmd+b"]

# Tabs / spaces
new_tab = ["prefix+c", "cmd+t"]
new_workspace = ["prefix+shift+n", "cmd+n"]

# Rename
rename_tab = ["prefix+shift+t", "cmd+shift+t"]
rename_workspace = ["prefix+shift+w", "cmd+shift+r"]

# Splits: split_vertical is side-by-side; split_horizontal is stacked.
split_vertical = ["prefix+v", "cmd+d"]
split_horizontal = ["prefix+minus", "cmd+shift+d"]

# Close (herdr cascades pane -> tab -> workspace internally)
close_pane = ["prefix+x", "cmd+w"]

# Indexed jumps. AeroSpace owns cmd+1..9.
#   ctrl+1..9       -> focus agent
#   alt(option)+1..9 -> switch tab
#   cmd+ctrl+1..9   -> switch workspace
focus_agent = "ctrl+1..9"
switch_tab = ["prefix+1..9", "alt+1..9"]
switch_workspace = "cmd+ctrl+1..9"

# Workspace picker + last-pane toggle.
workspace_picker = ["prefix+w", "cmd+p"]
last_pane = "cmd+o"

# Detach avoids macOS quit/logout chords.
detach = ["prefix+q", "cmd+ctrl+w"]
{{- else }}
toggle_sidebar = ["prefix+b", "alt+b"]

# Tabs / spaces
new_tab = ["prefix+c", "alt+t"]
new_workspace = ["prefix+shift+n", "alt+n"]

# Rename
rename_tab = ["prefix+shift+t", "alt+shift+t"]
rename_workspace = ["prefix+shift+w", "alt+shift+r"]

# Splits: split_vertical is side-by-side; split_horizontal is stacked.
split_vertical = ["prefix+v", "alt+d"]
split_horizontal = ["prefix+minus", "alt+shift+d"]

# Close (herdr cascades pane -> tab -> workspace internally)
close_pane = ["prefix+x", "alt+w"]

# Indexed jumps.
#   ctrl+1..9        -> focus agent
#   super+1..9       -> switch tab
#   alt+ctrl+1..9    -> switch workspace
focus_agent = "ctrl+1..9"
switch_tab = ["prefix+1..9", "super+1..9"]
switch_workspace = "alt+ctrl+1..9"

# Workspace picker + last-pane toggle.
workspace_picker = ["prefix+w", "alt+p"]
last_pane = "alt+o"

detach = ["prefix+q", "alt+ctrl+w"]
{{- end }}

# Pane navigation. Adds Vim-style direct nav (alt+hjkl on Linux, cmd+hjkl on
# macOS) alongside the existing prefix+hjkl and ctrl+shift+arrows/hjkl.
{{- if eq .chezmoi.os "darwin" }}
focus_pane_left = ["prefix+h", "ctrl+shift+left", "ctrl+shift+h", "cmd+h"]
focus_pane_down = ["prefix+j", "ctrl+shift+down", "ctrl+shift+j", "cmd+j"]
focus_pane_up = ["prefix+k", "ctrl+shift+up", "ctrl+shift+k", "cmd+k"]
focus_pane_right = ["prefix+l", "ctrl+shift+right", "ctrl+shift+l", "cmd+l"]
{{- else }}
focus_pane_left = ["prefix+h", "ctrl+shift+left", "ctrl+shift+h", "alt+h"]
focus_pane_down = ["prefix+j", "ctrl+shift+down", "ctrl+shift+j", "alt+j"]
focus_pane_up = ["prefix+k", "ctrl+shift+up", "ctrl+shift+k", "alt+k"]
focus_pane_right = ["prefix+l", "ctrl+shift+right", "ctrl+shift+l", "alt+l"]
{{- end }}
